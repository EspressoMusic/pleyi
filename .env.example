# Firebase (public web config — copy to data/firebase.json or set env vars)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# Firebase Admin (server-side) — required in production so premium/subscription
# status survives redeploys. Paste the full service account JSON as one line,
# or save it to data/firebase-service-account.json for local dev.
# Firebase Console → Project settings → Service accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT=

# AI — turn lesson text into game pairs (OpenAI is used first if both are set)
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
